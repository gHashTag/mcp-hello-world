{
  "name": "mcp-hello-world",
  "version": "1.0.0",
  "description": "Hello World example of MCP protocol with bot implementation",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "swc src -d dist",
    "build:watch": "swc src -d dist -w",
    "start": "node dist/index.js",
    "test": "node dist/test-utils/bot.test.js",
    "test:agent": "node dist/test-utils/agent.test.js",
    "test:telegram": "node dist/test-utils/telegram-self-improvement.js",
    "test:telegram:dev": "tsx src/test-utils/telegram-self-improvement.test.ts",
    "dev": "npm run build && npm run start",
    "mock-server": "node dist/test-utils/mock-server.js",
    "test:full": "npm run build && (npm run mock-server & sleep 2 && npm run test:telegram)",
    "system": "node dist/test-utils/run-agent-system.js",
    "telegram": "node dist/bot/telegram/index.js"
  },
  "keywords": [
    "mcp",
    "bot",
    "agent",
    "autonomous"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "@swc/cli": "^0.3.13",
    "@swc/core": "^1.4.8",
    "dotenv": "^16.3.1",
    "express": "^4.19.2",
    "telegraf": "^4.15.3",
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@types/ws": "^8.5.10",
    "tsx": "^4.19.3",
    "typescript": "^5.4.5"
  }
}

{
  "name": "mcp-dev",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint . --ext .ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "start:server": "node dist/server.js",
    "start:client": "node dist/client.js",
    "dev:server": "node --loader ts-node/esm src/server.ts",
    "dev:client": "node --loader ts-node/esm src/client.ts",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up",
    "docker:test": "docker-compose run --rm mcp-client npm run test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Development bot with MCP integration",
  "main": "dist/index.js",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "@types/express": "^4.17.21",
    "express": "^4.18.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}

{
  "name": "mcp-hello-world",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "swc src -d dist",
    "build:watch": "swc src -d dist -w",
    "start": "node dist/index.js",
    "start:server": "node dist/server.js",
    "start:client": "node dist/client.js",
    "dev:server": "node --loader ts-node/esm src/server.ts",
    "dev:client": "node --loader ts-node/esm src/client.ts",
    "test": "node dist/test-utils/bot.test.js",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up",
    "docker:test": "docker-compose -f docker-compose.test.yml run test",
    "dev": "npm run build && npm run start"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.0.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.28",
    "@types/ws": "^8.5.10",
    "express": "^4.18.3",
    "typescript": "^5.4.2",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@swc/cli": "^0.3.10",
    "@swc/core": "^1.4.8",
    "ts-node": "^10.9.2"
  }
}

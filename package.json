{
  "name": "mcp-hello-world",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/index.js",
    "start:server": "node dist/server.js",
    "start:client": "node dist/client.js",
    "dev:server": "node --loader ts-node/esm src/server.ts",
    "dev:client": "node --loader ts-node/esm src/client.ts",
    "test": "node --loader ts-node/esm test-utils/hello-test.ts",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up",
    "docker:test": "docker-compose run --rm mcp-client npm run test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.24",
    "express": "^4.18.2",
    "typescript": "^5.3.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "ts-node": "^10.9.2"
  }
}
